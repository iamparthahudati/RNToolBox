# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Required for @react-native-firebase with Firebase 11.x (Swift-based pods).
# Builds Firebase as a static framework so FirebaseAuth-Swift.h is generated
# before dependent targets compile.
use_frameworks! :linkage => :static
$RNFirebaseAsStaticFramework = true

target 'RNToolbox' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Firebase — core SDK (required by all other Firebase modules)
  pod 'FirebaseCore', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'FirebaseABTesting', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'GoogleSignIn', :modular_headers => true
  pod 'FirebaseAuth', :modular_headers => true
  pod 'FirebaseAuthInterop', :modular_headers => true
  pod 'FirebaseAppCheckInterop', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'RecaptchaInterop', :modular_headers => true

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Set the correct .env file for react-native-config per build configuration
    envfiles = {
      'Debug'   => '$(PODS_ROOT)/../../.env.debug',
      'Release' => '$(PODS_ROOT)/../../.env.production',
    }
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        if target.name == 'react-native-config'
          config.build_settings['ENVFILE'] = envfiles[config.name] || '$(PODS_ROOT)/../../.env.debug'
        end
      end
    end
  end
end
