# Environment: Debug — copy this file to .env.debug and fill in your keys
usesCleartextTraffic=true
APP_NAME=RNToolBox Debug
APP_ENV=debug
APP_VERSION=1.0.0

# API
API_BASE_URL=https://dev-api.rntoolbox.io/v1
API_TIMEOUT=10000

# Logging & Analytics
ENABLE_LOGS=true
ENABLE_ANALYTICS=false

# Sentry
SENTRY_DSN=YOUR_SENTRY_DSN

# Feature Flags
FEATURE_FLAG_NEW_UI=true

# Maps
MAPS_API_KEY=YOUR_GOOGLE_MAPS_ANDROID_API_KEY
MAPS_API_KEY_IOS=YOUR_GOOGLE_MAPS_IOS_API_KEY

# Google Sign-In
GOOGLE_WEB_CLIENT_ID=YOUR_DEV_WEB_CLIENT_ID.apps.googleusercontent.com
