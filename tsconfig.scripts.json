{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": ".scripts-dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "moduleResolution": "node",
    "paths": {}
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
